# Server Port Configuration
PORT=5000
NODE_ENV=development

# Database connection URL (Neon / PostgreSQL)
# Example: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/driply?schema=public

# Authentication Security Secrets
# Generate random 32+ character strings (e.g. openssl rand -base64 32)
JWT_SECRET=super_secret_access_token_key_change_me
JWT_REFRESH_SECRET=super_secret_refresh_token_key_change_me

# Cloudinary Integration for Media Uploads
CLOUDINARY_CLOUD_NAME=driply_cloud
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Gemini AI (required for clothing identification and smart outfit suggestions)
GEMINI_API_KEY=your_gemini_api_key
